{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "github>Syriiin/renovate-config"
  ],
  "packageRules": [
    {
      "matchManagers": [
        "poetry"
      ],
      "matchDepTypes": [
        "dev"
      ],
      "groupName": "poetry-dev-dependencies"
    },
    {
      "matchManagers": [
        "docker-compose"
      ],
      "matchPackageNames": [
        "/difficalcy/"
      ],
      "groupName": "difficalcy"
    }
  ],
  "lockFileMaintenance": {
    "enabled": true
  }
}
